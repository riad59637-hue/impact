            "liquid": "<p id=\"delivery-msg\" style=\"font-family:'Jost',sans-serif;font-size:13px;color:#1a0a08;text-align:center;margin:12px 0;\">\n  <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#1a0a08\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:6px;\">\n    <rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"1\"/>\n    <path d=\"M16 8h4l3 5v3h-7V8z\"/>\n    <circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/>\n    <circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/>\n  </svg>\n  <span id=\"delivery-text\" style=\"vertical-align:middle;\"></span>\n</p>\n\n<script>\n(function() {\n  const mois = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];\n  function addJoursOuvres(date, jours) {\n    let d = new Date(date);\n    let count = 0;\n    while (count < jours) {\n      d.setDate(d.getDate() + 1);\n      const dow = d.getDay();\n      if (dow !== 0 && dow !== 6) count++;\n    }\n    return d;\n  }\n  const now = new Date();\n  const min = addJoursOuvres(now, 2);\n  const max = addJoursOuvres(now, 5);\n  const minStr = min.getDate() + ' ' + mois[min.getMonth()];\n  const maxStr = max.getDate() + ' ' + mois[max.getMonth()];\n  document.getElementById('delivery-text').innerHTML =\n    'Commandez maintenant et recevez le <strong>' + minStr + ' – ' + maxStr + '</strong>';\n})();\n</script>"
